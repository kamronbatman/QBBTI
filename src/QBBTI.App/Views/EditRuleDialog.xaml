<Window x:Class="QBBTI.App.Views.EditRuleDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edit Mapping Rule" Height="400" Width="500"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        ShowInTaskbar="False"
        Icon="/Resources/bank.png">

    <StackPanel Margin="20">
        <!-- Sample context -->
        <TextBlock TextWrapping="Wrap" Margin="0,0,0,4" FontSize="12" Foreground="#666">
            <Run Text="Sample: " />
            <Run Text="{Binding SampleDescription, Mode=OneWay}" FontStyle="Italic" />
            <Run Text="  $" /><Run Text="{Binding SampleAmount, Mode=OneWay, StringFormat=N2}" />
        </TextBlock>
        <TextBlock Margin="0,0,0,16" FontSize="12" Foreground="#666">
            <Run Text="{Binding TransactionCount, Mode=OneWay}" />
            <Run Text=" transaction(s) in this group" />
        </TextBlock>

        <!-- Pattern -->
        <TextBlock Text="Match Pattern:" FontWeight="SemiBold" Margin="0,0,0,4" />
        <TextBox Text="{Binding Pattern, UpdateSourceTrigger=PropertyChanged}"
                 FontFamily="Consolas" FontSize="12" Margin="0,0,0,4" Padding="4" />
        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
            <RadioButton Content="Regex" GroupName="MatchMode" IsChecked="{Binding IsRegex}" Margin="0,0,16,0" />
            <RadioButton Content="Contains" GroupName="MatchMode" IsChecked="{Binding IsContains}" />
        </StackPanel>

        <!-- Amount range -->
        <CheckBox Content="Restrict by Amount Range" IsChecked="{Binding UseAmountRange}" Margin="0,0,0,8" />
        <StackPanel Orientation="Horizontal" Margin="20,0,0,12"
                    IsEnabled="{Binding UseAmountRange}">
            <TextBlock Text="Min: $" VerticalAlignment="Center" Margin="0,0,4,0" />
            <TextBox Text="{Binding MinAmount, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}"
                     Width="100" Padding="4" Margin="0,0,16,0" />
            <TextBlock Text="Max: $" VerticalAlignment="Center" Margin="0,0,4,0" />
            <TextBox Text="{Binding MaxAmount, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}"
                     Width="100" Padding="4" />
        </StackPanel>

        <!-- Memo -->
        <TextBlock Text="Memo (optional):" FontWeight="SemiBold" Margin="0,0,0,4" />
        <TextBox Text="{Binding Memo, UpdateSourceTrigger=PropertyChanged}"
                 Margin="0,0,0,20" Padding="4" />

        <!-- Buttons -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel" Click="OnCancel" Style="{StaticResource SecondaryButton}"
                    Width="90" Margin="0,0,8,0" />
            <Button Content="Save Rule" Click="OnSave" Style="{StaticResource PrimaryButton}" Width="100" />
        </StackPanel>
    </StackPanel>
</Window>
