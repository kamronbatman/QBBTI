<UserControl x:Class="QBBTI.App.Views.ReviewView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:QBBTI.App.ViewModels">

    <DockPanel>
        <!-- Top toolbar — Review mode -->
        <Border DockPanel.Dock="Top" Background="#F5F5F5" Padding="16,8" BorderBrush="#DDD" BorderThickness="0,0,0,1">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Visible" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsPreviewVisible}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <DockPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Content="Back" Command="{Binding GoBackCommand}"
                            Style="{StaticResource SecondaryButton}" Margin="0,0,8,0" />
                    <Button Content="Import Selected" Command="{Binding ImportSelectedCommand}"
                            IsEnabled="{Binding IsImporting, Converter={StaticResource InverseBoolConverter}}"
                            Style="{StaticResource PrimaryButton}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock FontSize="14" FontWeight="SemiBold">
                        <Run Text="{Binding TotalTransactions, Mode=OneWay}" />
                        <Run Text=" transactions" />
                    </TextBlock>
                    <TextBlock Margin="16,0,0,0" Foreground="Green">
                        <Run Text="{Binding AutoMappedCount, Mode=OneWay}" />
                        <Run Text=" auto-mapped" />
                    </TextBlock>
                    <TextBlock Margin="16,0,0,0" Foreground="#B8860B">
                        <Run Text="{Binding UnmatchedCount, Mode=OneWay}" />
                        <Run Text=" unmatched" />
                    </TextBlock>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Top toolbar — Preview mode -->
        <Border DockPanel.Dock="Top" Background="#F0F4FF" Padding="16,8" BorderBrush="#B0C4DE" BorderThickness="0,0,0,1"
                Visibility="{Binding IsPreviewVisible, Converter={StaticResource BoolToVisibilityConverter}}">
            <DockPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Content="Cancel" Command="{Binding CancelPreviewCommand}"
                            Style="{StaticResource SecondaryButton}" Margin="0,0,8,0" />
                    <Button Content="Confirm Import" Command="{Binding ConfirmImportCommand}"
                            IsEnabled="{Binding IsImporting, Converter={StaticResource InverseBoolConverter}}"
                            Style="{StaticResource PrimaryButton}" />
                </StackPanel>
                <TextBlock FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center">
                    <Run Text="QBXML Preview — " />
                    <Run Text="{Binding PreviewItems.Count, Mode=OneWay}" />
                    <Run Text=" transactions" />
                </TextBlock>
            </DockPanel>
        </Border>

        <!-- Progress bar -->
        <Border DockPanel.Dock="Bottom" Padding="16,8"
                Visibility="{Binding IsImporting, Converter={StaticResource BoolToVisibilityConverter}}">
            <StackPanel>
                <ProgressBar Value="{Binding ImportProgress}" Height="20" Margin="0,0,0,4" />
                <TextBlock Text="{Binding ImportStatusText}" FontSize="12" Foreground="#666" />
            </StackPanel>
        </Border>

        <!-- Import status (when not importing but has status text) -->
        <Border DockPanel.Dock="Bottom" Padding="16,4"
                Visibility="{Binding ImportStatusText, Converter={StaticResource NullToCollapsedConverter}}">
            <TextBlock Text="{Binding ImportStatusText}" FontSize="12" Foreground="#666" />
        </Border>

        <!-- Groups list (review mode) -->
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <ScrollViewer.Style>
                <Style TargetType="ScrollViewer">
                    <Setter Property="Visibility" Value="Visible" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsPreviewVisible}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </ScrollViewer.Style>
            <ItemsControl ItemsSource="{Binding Groups}" Margin="8">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:TransactionGroupViewModel}">
                        <Border Margin="8,4" CornerRadius="6" BorderBrush="#DDD" BorderThickness="1"
                                Background="{Binding IsAutoMapped, Converter={StaticResource BoolToColorConverter}}"
                                AllowDrop="True" DragOver="GroupBorder_DragOver" Drop="GroupBorder_Drop"
                                DragEnter="GroupBorder_DragEnter" DragLeave="GroupBorder_DragLeave">
                            <StackPanel>
                                <!-- Group header -->
                                <DockPanel Margin="12,8">
                                    <!-- Drag grip handle -->
                                    <TextBlock DockPanel.Dock="Left" Text="&#x283F;" FontSize="14"
                                               Foreground="#AAA" Cursor="SizeAll" VerticalAlignment="Center"
                                               Margin="0,0,6,0" ToolTip="Drag to merge with another group"
                                               PreviewMouseLeftButtonDown="GripHandle_PreviewMouseLeftButtonDown" />

                                    <!-- Expand/collapse toggle -->
                                    <ToggleButton DockPanel.Dock="Left" IsChecked="{Binding IsExpanded}"
                                                  Width="24" Height="24" Margin="0,0,8,0"
                                                  Background="Transparent" BorderThickness="0">
                                        <ToggleButton.Style>
                                            <Style TargetType="ToggleButton">
                                                <Setter Property="Content" Value="+" />
                                                <Style.Triggers>
                                                    <Trigger Property="IsChecked" Value="True">
                                                        <Setter Property="Content" Value="-" />
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ToggleButton.Style>
                                    </ToggleButton>

                                    <!-- Checkbox -->
                                    <CheckBox DockPanel.Dock="Left" IsChecked="{Binding IsSelected}"
                                              VerticalAlignment="Center" Margin="0,0,8,0" />

                                    <!-- Save Mapping button -->
                                    <Button DockPanel.Dock="Right" Content="Save Mapping"
                                            Command="{Binding DataContext.SaveMappingCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}"
                                            Style="{StaticResource SecondaryButton}"
                                            FontSize="11" Padding="10,4" Margin="8,0,0,0" />

                                    <!-- Summary info -->
                                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Margin="12,0,0,0"
                                                VerticalAlignment="Center">
                                        <TextBlock Text="{Binding TransactionCount, StringFormat='{}{0} txn'}"
                                                   Foreground="#666" Margin="0,0,4,0" />
                                        <TextBlock Foreground="#D2691E" Margin="0,0,4,0"
                                                   Visibility="{Binding HasDuplicates, Converter={StaticResource BoolToVisibilityConverter}}">
                                            <Run Text="(" /><Run Text="{Binding DuplicateCount, Mode=OneWay}" /><Run Text=" dup)" />
                                        </TextBlock>
                                        <TextBlock Text="{Binding AmountSummary}" FontWeight="SemiBold"
                                                   TextAlignment="Right" />
                                    </StackPanel>

                                    <!-- Editable fields -->
                                    <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                                        <ComboBox ItemsSource="{Binding AvailablePayees}"
                                                  Text="{Binding PayeeName, UpdateSourceTrigger=LostFocus}"
                                                  IsEditable="True" Width="180" Padding="4,3" Margin="0,0,8,0"
                                                  FontWeight="SemiBold" />
                                        <ComboBox ItemsSource="{Binding AvailableAccounts}"
                                                  SelectedItem="{Binding AccountName}"
                                                  IsEditable="True" Width="200" Padding="4,3" Margin="0,0,8,0" />
                                    </StackPanel>

                                    <!-- Raw description fills remaining space -->
                                    <TextBlock Text="{Binding GroupDescription}" Foreground="#888"
                                               FontStyle="Italic" VerticalAlignment="Center" Margin="8,0,0,0"
                                               TextTrimming="CharacterEllipsis"
                                               Visibility="{Binding GroupDescription, Converter={StaticResource NullToCollapsedConverter}}" />
                                </DockPanel>

                                <!-- Expanded transaction details -->
                                <ItemsControl ItemsSource="{Binding Transactions}"
                                              Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="{x:Type vm:BankTransactionViewModel}">
                                            <Border Padding="40,4,12,4" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0">
                                                <DockPanel>
                                                    <CheckBox DockPanel.Dock="Left" IsChecked="{Binding IsCheckedForGrouping}"
                                                              VerticalAlignment="Center" Margin="0,0,8,0" />
                                                    <Button DockPanel.Dock="Right" Content="Ungroup" FontSize="11"
                                                            Command="{Binding DataContext.UngroupCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                            CommandParameter="{Binding}"
                                                            Style="{StaticResource SecondaryButton}"
                                                            Padding="8,2" Margin="8,0,0,0" />
                                                    <TextBlock DockPanel.Dock="Left"
                                                               Text="{Binding Date, StringFormat='{}{0:MM/dd/yyyy}'}"
                                                               Width="80" Foreground="#666" />
                                                    <TextBlock DockPanel.Dock="Right" Text="{Binding AmountDisplay}"
                                                               Width="80" TextAlignment="Right"
                                                               FontWeight="SemiBold" Margin="8,0,0,0" />
                                                    <TextBlock DockPanel.Dock="Right" Text="{Binding CheckNumber}"
                                                               Width="60" Foreground="#666" Margin="8,0,0,0" />
                                                    <StackPanel>
                                                        <DockPanel>
                                                            <TextBlock DockPanel.Dock="Right" Text="Possible duplicate"
                                                                       Foreground="#D2691E" FontWeight="SemiBold" FontSize="11"
                                                                       Margin="8,0,0,0" VerticalAlignment="Center"
                                                                       Visibility="{Binding IsPossibleDuplicate, Converter={StaticResource BoolToVisibilityConverter}}" />
                                                            <TextBlock Text="{Binding RawDescription}" TextWrapping="Wrap"
                                                                       Foreground="#444" />
                                                        </DockPanel>
                                                        <TextBlock Text="{Binding Memo}" TextWrapping="Wrap"
                                                                   Foreground="#999" FontSize="11" FontStyle="Italic"
                                                                   Visibility="{Binding Memo, Converter={StaticResource NullToCollapsedConverter}}" />
                                                    </StackPanel>
                                                </DockPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <!-- Ungroup Checked bar -->
                                <Border Padding="40,6,12,6" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0"
                                        Background="#F0F0F0">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <MultiDataTrigger>
                                                    <MultiDataTrigger.Conditions>
                                                        <Condition Binding="{Binding IsExpanded}" Value="True" />
                                                        <Condition Binding="{Binding HasCheckedTransactions}" Value="True" />
                                                    </MultiDataTrigger.Conditions>
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </MultiDataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <DockPanel>
                                        <Button DockPanel.Dock="Right" Content="Ungroup Checked"
                                                Command="{Binding UngroupCheckedCommand}"
                                                Style="{StaticResource SecondaryButton}"
                                                FontSize="11" Padding="10,4" />
                                        <TextBlock VerticalAlignment="Center" Foreground="#666">
                                            <Run Text="{Binding CheckedTransactionCount, Mode=OneWay}" />
                                            <Run Text=" selected" />
                                        </TextBlock>
                                    </DockPanel>
                                </Border>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Preview panel (preview mode) -->
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="8"
                      Visibility="{Binding IsPreviewVisible, Converter={StaticResource BoolToVisibilityConverter}}">
            <ItemsControl ItemsSource="{Binding PreviewItems}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="8,4" CornerRadius="6" BorderBrush="#B0C4DE" BorderThickness="1"
                                Background="#FAFCFF">
                            <StackPanel>
                                <!-- Summary line with expand toggle -->
                                <DockPanel Margin="12,8">
                                    <ToggleButton x:Name="XmlToggle" DockPanel.Dock="Left"
                                                  Width="24" Height="24" Margin="0,0,8,0"
                                                  Background="Transparent" BorderThickness="0">
                                        <ToggleButton.Style>
                                            <Style TargetType="ToggleButton">
                                                <Setter Property="Content" Value="+" />
                                                <Style.Triggers>
                                                    <Trigger Property="IsChecked" Value="True">
                                                        <Setter Property="Content" Value="-" />
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ToggleButton.Style>
                                    </ToggleButton>
                                    <TextBlock Text="{Binding Summary}" VerticalAlignment="Center"
                                               FontSize="13" FontWeight="SemiBold" />
                                </DockPanel>

                                <!-- Collapsible QBXML -->
                                <Border Padding="16,8" Background="#F5F5F5" BorderBrush="#E0E0E0"
                                        BorderThickness="0,1,0,0"
                                        Visibility="{Binding IsChecked, ElementName=XmlToggle, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <TextBlock Text="{Binding Xml}" FontFamily="Consolas" FontSize="11"
                                               Foreground="#333" TextWrapping="Wrap" />
                                </Border>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </DockPanel>
</UserControl>
