<Window x:Class="QBBTI.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:QBBTI.App.ViewModels"
        xmlns:views="clr-namespace:QBBTI.App.Views"
        Title="QuickBooks Bank Transaction Importer" Height="600" Width="1024"
        MinWidth="900" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Icon="/Resources/bank.png">

    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:ImportViewModel}">
            <views:ImportView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ReviewViewModel}">
            <views:ReviewView />
        </DataTemplate>
    </Window.Resources>

    <DockPanel>
        <!-- Status Bar -->
        <StatusBar DockPanel.Dock="Bottom" Padding="8,4">
            <TextBlock Text="{Binding StatusText}" />
        </StatusBar>

        <!-- Header -->
        <Border DockPanel.Dock="Top" Background="#0078D4" Padding="16,10">
            <DockPanel>
                <Button DockPanel.Dock="Right" Content="&#x24D8;" Click="AboutButton_Click"
                        FontSize="16" FontWeight="Bold" Foreground="White" Background="Transparent"
                        BorderThickness="0" Cursor="Hand" Padding="6,2" ToolTip="About"
                        VerticalAlignment="Center">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="12"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#005A9E" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <TextBlock Text="QuickBooks Bank Transaction Importer" FontSize="18"
                           FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center" />
            </DockPanel>
        </Border>

        <!-- Content -->
        <ContentControl Content="{Binding CurrentView}" Margin="0" />
    </DockPanel>
</Window>
